# ── Tesla Tracker Configuration ──────────────────────────────
# Copy this file to .env and fill in your values.

# ── Location ─────────────────────────────────────────────────
TESLA_ZIP=2759
TESLA_MARKET=AU
TESLA_LANGUAGE=en
TESLA_SUPER_REGION=north america
TESLA_LAT=-33.7462
TESLA_LNG=150.7936

# ── Scraping ─────────────────────────────────────────────────
# Interval in seconds (300 = 5 minutes). Actual interval is randomized ±30%.
SCRAPE_INTERVAL=300

# ── Email Notifications (Gmail) ──────────────────────────────
# To set up Gmail:
# 1. Go to https://myaccount.google.com/apppasswords
# 2. Generate an "App Password" for "Mail"
# 3. Use your Gmail address as SMTP_USER
# 4. Use the generated 16-char password as SMTP_PASSWORD
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=abcd efgh ijkl mnop
EMAIL_TO=your.email@gmail.com

# ── Push Notifications (ntfy.sh) ─────────────────────────────
# Free instant push notifications to your phone.
# 1. Install the ntfy app: Android (Play Store) or iOS (App Store)
# 2. Pick a unique, hard-to-guess topic name (it's like a channel)
# 3. Subscribe to that topic in the ntfy app
# 4. Set NTFY_TOPIC below to the same name
NTFY_ENABLED=false
NTFY_TOPIC=tesla-tracker-CHANGE-THIS-eshan
NTFY_SERVER=https://ntfy.sh

# ── Web Dashboard ────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
BASE_PATH=/tesla

# ── Proxy (required on VPS — Tesla blocks datacenter IPs) ───
# Leave blank if running on a home/residential IP.
# Get a residential proxy from Webshare (free tier: webshare.io)
# Format: http://user:pass@proxy-host:port
PROXY_URL=

# ── Database ─────────────────────────────────────────────────
DB_PATH=tesla_inventory.db
